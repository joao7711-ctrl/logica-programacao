programa {
  funcao inicio() {
    real salario, horas, htrabalhada
    escreva("VAMOS CALCULAR O VALOR DA SUA HORA DE TRABALHO !!\n")
    escreva("Digite o valor do seu salario: \n")
    leia(salario)
    escreva("Digite quantas quantas horas voce trabalhou esse mês: \n")
    leia(horas)
    escreva("O Valor da sua Hora trabalhada é: R$", salario/horas)

    
  }
}
