programa {
  funcao inicio() {
    real media1
    escreva("Digite a nota da primeira prova: ")
    leia(media1)
    real media2
    escreva("Digite a nota da segunda prova: ")
    leia(media2)
    real resultado
    resultado = (media1 + media2) / 2
    escreva("A Média final do aluno é: ", resultado)
    
  }
}
