programa {
  funcao inicio() {
    inteiro numero
    escreva("Digite um número inteiro qualquer que vou te mostrar o número antecessor e sucessor do mesmo !!!\n")
    escreva("Digite o número: ")
    leia (numero)
    escreva("O antecessor do numero: ", numero," é: ", numero-1,"\n")
    escreva("O sucessor do numero: ", numero," é: ", numero+1,"\n")
    
  }
}
